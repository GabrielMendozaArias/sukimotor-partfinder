function obtenerVerificacionesEntreFechas(fechaInicio, fechaFin) {
  const sm = new SheetManager();
  const sheet = sm.ss.getSheetByName("Verificaciones");
  
  if (!sheet) {
    Logger.log(" Hoja 'Verificaciones' no existe");
    return [];
  }
  
  const datos = sheet.getDataRange().getValues();
  const verificaciones = [];
  
  Logger.log(` Verificaciones - Total filas: ${datos.length - 1}`);
  
  // Normalizar fechas de búsqueda
  const inicio = new Date(fechaInicio);
  inicio.setHours(0, 0, 0, 0);
  const fin = new Date(fechaFin);
  fin.setHours(23, 59, 59, 999);
  
  for (let i = 1; i < datos.length; i++) {
    try {
      // Validar que la fila no esté vacía
      if (!datos[i][0]) continue;
      
      // Parsear fecha con la función corregida
      let fecha = parseFechaLocal(datos[i][0]);
      
      if (!fecha) {
        Logger.log(` Fila ${i+1}: fecha inválida`);
        continue;
      }
      
      // Comparar fechas
      if (fecha >= inicio && fecha <= fin) {
        verificaciones.push({
          fecha: datos[i][0],
          ubicacion: datos[i][1] || "",
          validados: parseInt(datos[i][2]) || 0,
          intrusos: parseInt(datos[i][3]) || 0,
          faltantes: parseInt(datos[i][4]) || 0,
          tasaExito: datos[i][5] || "0%",
          usuario: datos[i][6] || "Desconocido"
        });
      }
      
    } catch (error) {
      Logger.log(` Error procesando fila ${i+1}: ${error.message}`);
      continue;
    }
  }
  
  Logger.log(` Verificaciones válidas en rango: ${verificaciones.length}`);
  return verificaciones;
}

