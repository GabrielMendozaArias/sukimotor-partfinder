function obtenerValoresUbicaciones() {
  try {
    const ubicaciones = getCachedUbicaciones();
    
    const zonas = [...new Set(ubicaciones.map(u => u.Zona || u['Zona']).filter(Boolean))].sort();
    const pasillos = [...new Set(ubicaciones.map(u => u.Pasillo || u['Pasillo']).filter(Boolean))].sort((a, b) => a - b);
    const anaqueles = [...new Set(ubicaciones.map(u => u.Anaquel || u['Anaquel']).filter(Boolean))].sort();
    const racks = [...new Set(ubicaciones.map(u => u.Rack || u['Rack']).filter(Boolean))].sort((a, b) => a - b);
    const niveles = [...new Set(ubicaciones.map(u => u.Nivel || u['Nivel']).filter(Boolean))].sort();
    
    return {
      success: true,
      zonas: zonas,
      pasillos: pasillos,
      anaqueles: anaqueles,
      racks: racks,
      niveles: niveles
    };
    
  } catch (error) {
    Logger.log("Error en obtenerValoresUbicaciones: " + error);
    return {
      success: false,
      message: error.toString()
    };
  }
}
