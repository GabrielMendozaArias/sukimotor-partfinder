function guardarVerificacion(datosVerificacion) {
  try {
    const sm = new SheetManager();
    const sheet = sm.getOrCreateSheet("Verificaciones");
    const session = getSessionUser(datosVerificacion.sessionId);
    
    if (!session.success) {
      return { success: false, message: "Sesión inválida" };
    }
    
    const ubicacion = datosVerificacion.ubicacion;
    const codigosEsperados = datosVerificacion.codigosEsperados || [];
    const codigosEncontrados = datosVerificacion.codigosEncontrados || [];
    
    // Calcular métricas
    const validados = codigosEncontrados.filter(c => codigosEsperados.includes(c)).length;
    const intrusos = codigosEncontrados.filter(c => !codigosEsperados.includes(c));
    const ausentes = codigosEsperados.filter(c => !codigosEncontrados.includes(c));
    
    const tasaExito = codigosEsperados.length > 0 
      ? ((validados / codigosEsperados.length) * 100).toFixed(2) 
      : 100;
    
    const detalles = JSON.stringify({
      esperados: codigosEsperados,
      encontrados: codigosEncontrados,
      validados: codigosEncontrados.filter(c => codigosEsperados.includes(c)),
      intrusos: intrusos,
      ausentes: ausentes
    });
    
    //  CREAR ESTRUCTURA DE CARPETAS
    const idVerificacion = "VER-" + Utilities.formatDate(new Date(), "GMT-5", "yyyyMMdd-HHmmss");
    const carpetas = obtenerCarpetaReportes("Verificaciones", idVerificacion);
    
    // Eliminar ubicación de códigos ausentes
    if (ausentes.length > 0) {
      Logger.log(`Procesando ${ausentes.length} códigos ausentes para eliminar ubicación ${ubicacion}`);
      
      ausentes.forEach(codigoAusente => {
        const resultado = eliminarUbicacionEspecifica(codigoAusente, ubicacion);
        if (resultado.exito) {
          Logger.log(`✓ ${resultado.mensaje}`);
        } else {
          Logger.log(`✗ ${resultado.mensaje}`);
        }
      });
    }
    
    // Guardar en sheet
    const timestamp = new Date().toLocaleString("es-PA");
    sheet.appendRow([
      timestamp,
      ubicacion,
      validados,
      intrusos.length,
      ausentes.length,
      tasaExito + "%",
      session.user.email,
      detalles,
      idVerificacion,
      carpetas.success ? carpetas.rutaCompleta : ""
    ]);
    
    //  GENERAR PDF Y GUARDARLO EN SUBCARPETA
    let urlReporte = "";
    if (carpetas.success) {
      const datosCompletos = {
        id: idVerificacion,
        ubicacion: ubicacion,
        validados: validados,
        intrusos: intrusos,
        ausentes: ausentes,
        tasaExito: parseFloat(tasaExito),
        usuario: session.user.email,
        codigosEsperados: codigosEsperados,
        codigosEncontrados: codigosEncontrados,
        fecha: timestamp,
        carpetaDrive: carpetas.rutaCompleta
      };
      
      urlReporte = generarReporteVerificacionPDF(datosCompletos, carpetas.carpetaReporte);
    }
    
    // Enviar email
    const emailMgr = new EmailManagerRobusto(sm);
    const htmlReporte = generarHTMLVerificacionIndividual({
      ubicacion: ubicacion,
      validados: validados,
      intrusos: intrusos,
      ausentes: ausentes,
      tasaExito: parseFloat(tasaExito),
      usuario: session.user.email,
      codigosEsperados: codigosEsperados,
      codigosEncontrados: codigosEncontrados,
      fecha: timestamp
    });
    
    const resultadoEmail = emailMgr.enviarReporte(
      "DIARIO",
      {
        id: idVerificacion,
        fechaGeneracion: timestamp
      },
      ` Verificación: ${ubicacion} (${tasaExito}% éxito)`,
      htmlReporte
    );
    
    return { 
      success: true, 
      message: 'Verificación guardada exitosamente',
      idVerificacion: idVerificacion,
      urlReporte: urlReporte,
      carpeta: carpetas.success ? carpetas.rutaCompleta : null,
      emailEnviado: resultadoEmail.enviados > 0,
      metricas: {
        validados: validados,
        intrusos: intrusos.length,
        ausentes: ausentes.length,
        tasaExito: tasaExito
      },
      ausentesProcesados: ausentes.length
    };
    
  } catch (error) {
    Logger.log('Error en guardarVerificacion: ' + error);
    return { success: false, message: 'Error: ' + error.message };
  }
}
