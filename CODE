function obtenerDatosJefeBodega() {
  try {
    const sm = new SheetManager();
    const inventario = getCachedInventario();
    
    // Stats generales
    const stats = obtenerEstadisticasDashboard();
    
    // Verificaciones recientes
    const verificacionesSheet = sm.ss.getSheetByName("Verificaciones");
    const verificaciones = verificacionesSheet ? verificacionesSheet.getDataRange().getValues() : [];
    
    // Auditorías
    const auditoriasSheet = sm.ss.getSheetByName("Auditorias");
    const auditorias = auditoriasSheet ? auditoriasSheet.getDataRange().getValues() : [];
    
    // Recepciones
    const recepcionesSheet = sm.ss.getSheetByName("Recepciones");
    const recepciones = recepcionesSheet ? recepcionesSheet.getDataRange().getValues() : [];
    
    // Calcular progreso de verificaciones (ejemplo: ubicaciones verificadas vs total)
    const ubicaciones = getCachedUbicaciones();
    const ubicacionesVerificadas = new Set(verificaciones.slice(1).map(v => v[1]));
    const progresoVerificacion = ubicaciones.length > 0 
      ? ((ubicacionesVerificadas.size / ubicaciones.length) * 100).toFixed(1)
      : 0;
    
    return {
      success: true,
      stats: {
        totalArticulos: stats.totalRepuestos,
        totalUbicaciones: ubicaciones.length,
        totalAuditorias: auditorias.length - 1,
        totalRecepciones: recepciones.length - 1,
        verificacionesCompletadas: ubicacionesVerificadas.size,
        verificacionesTotales: ubicaciones.length,
        progresoVerificacion: progresoVerificacion
      },
      rendimientoAlmacenistas: calcularRendimiento(verificaciones)
    };
  } catch (error) {
    return { success: false, message: error.toString() };
  }
}

function calcularRendimiento(verificaciones) {
  // Análisis de últimos 7 días
  const hace7Dias = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);
  const verificacionesRecientes = verificaciones.slice(1).filter(v => {
    const fecha = new Date(v[0]);
    return fecha >= hace7Dias;
  });
  
  // Agrupar por usuario
  const porUsuario = {};
  verificacionesRecientes.forEach(v => {
    const usuario = v[6];
    if (!porUsuario[usuario]) {
      porUsuario[usuario] = { verificaciones: 0, codigosValidados: 0, intrusos: 0, precisionTotal: 0 };
    }
    porUsuario[usuario].verificaciones++;
    porUsuario[usuario].codigosValidados += parseInt(v[2]) || 0;
    porUsuario[usuario].intrusos += parseInt(v[3]) || 0;
    
    const tasaStr = v[5] || "0%";
    const tasa = parseFloat(tasaStr.replace("%", ""));
    porUsuario[usuario].precisionTotal += tasa;
  });
  
  // Calcular métricas
  const resultado = [];
  Object.keys(porUsuario).forEach(usuario => {
    const data = porUsuario[usuario];
    const precision = data.verificaciones > 0 
      ? (data.precisionTotal / data.verificaciones).toFixed(1) 
      : 0;
    
    const codigosPorHora = data.verificaciones > 0 
      ? (data.codigosValidados / (data.verificaciones * 0.5)).toFixed(1) // Asumiendo 30min por verificación
      : 0;
    
    resultado.push({
      usuario: usuario,
      codigosPorHora: codigosPorHora,
      precision: precision + "%",
      intrusos: data.intrusos,
      estado: data.intrusos > 5 ? " Revisar" : " OK"
    });
  });
  
  return resultado;
}

function obtenerDatosVisualizador(filtros) {
  try {
    const sm = new SheetManager();
    const fechaInicio = filtros.fechaInicio ? new Date(filtros.fechaInicio) : new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
    const fechaFin = filtros.fechaFin ? new Date(filtros.fechaFin) : new Date();
    const usuario = filtros.usuario || "";
    
    // Obtener datos de verificaciones
    const verificacionesSheet = sm.ss.getSheetByName("Verificaciones");
    const verificaciones = verificacionesSheet ? verificacionesSheet.getDataRange().getValues().slice(1) : [];
    
    const verificacionesFiltradas = verificaciones.filter(v => {
      const fecha = new Date(v[0]);
      const cumpleFecha = fecha >= fechaInicio && fecha <= fechaFin;
      const cumpleUsuario = !usuario || v[6].toLowerCase().includes(usuario.toLowerCase());
      return cumpleFecha && cumpleUsuario;
    });
    
    // Similar para auditorías y recepciones
    const auditoriasSheet = sm.ss.getSheetByName("Auditorias");
    const auditorias = auditoriasSheet ? auditoriasSheet.getDataRange().getValues().slice(1) : [];
    
    const recepcionesSheet = sm.ss.getSheetByName("Recepciones");
    const recepciones = recepcionesSheet ? recepcionesSheet.getDataRange().getValues().slice(1) : [];
    
    // Calcular precisión promedio
    let precisionTotal = 0;
    verificacionesFiltradas.forEach(v => {
      const tasaStr = v[5] || "0%";
      const tasa = parseFloat(tasaStr.replace("%", ""));
      precisionTotal += tasa;
    });
    const precisionPromedio = verificacionesFiltradas.length > 0 
      ? (precisionTotal / verificacionesFiltradas.length).toFixed(1) 
      : 0;
    
    // Detalle de operaciones
    const detalleOperaciones = [];
    
    verificacionesFiltradas.forEach(v => {
      detalleOperaciones.push({
        fecha: v[0],
        tipo: "Verificación",
        usuario: v[6],
        codigo: v[1], // Ubicación
        estado: v[5] // Tasa éxito
      });
    });
    
    return {
      success: true,
      stats: {
        verificaciones: verificacionesFiltradas.length,
        recepciones: recepciones.length,
        auditorias: auditorias.length,
        precision: precisionPromedio + "%"
      },
      detalle: detalleOperaciones.slice(0, 100) // Limitar a 100 registros
    };
  } catch (error) {
    return { success: false, message: error.toString() };
  }
}

