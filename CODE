//  VERIFICACIÓN MEJORADA - GESTIÓN DE INTRUSOS
// ========================================

function validarIntruso(ubicacion, codigo, accion, usuario) {
  try {
    const sm = new SheetManager();
    const intrusosSheet = sm.getOrCreateSheet("IntrusosValidados", 
      ["Ubicacion", "Codigo", "Accion", "Usuario", "Fecha", "Motivo"]);
    
    switch(accion) {
      case "AGREGAR_A_UBICACION":
        const cleanInfo = cleanPartCode(codigo);
        
        // 1. Obtener el registro actual del inventario
        const inventarioSheet = sm.ss.getSheetByName("Inventario");
        const datos = inventarioSheet.getDataRange().getValues();
        const headers = datos[0];
        
        // Encontrar índice de columna Código
        const colCodigo = headers.indexOf("Código");
        
        // Campos de ubicación en orden de prioridad
        const camposUbicacion = [
          "Ubicación Principal",
          "Ubicación 2", 
          "Ubicación 3", 
          "Ubicación 4", 
          "Ubicación 5"
        ];
        
        // 2. Buscar la fila del código
        let filaEncontrada = -1;
        for (let i = 1; i < datos.length; i++) {
          if (datos[i][colCodigo] === cleanInfo.clean) {
            filaEncontrada = i;
            break;
          }
        }
        
        if (filaEncontrada === -1) {
          return { success: false, message: "Código no encontrado en inventario" };
        }
        
        // 3. Buscar el primer campo de ubicación vacío
        let campoDisponible = null;
        let colDisponible = -1;
        
        for (let campo of camposUbicacion) {
          const colIndex = headers.indexOf(campo);
          if (colIndex === -1) continue;
          
          const valorActual = datos[filaEncontrada][colIndex];
          
          // Si ya tiene esta ubicación, no duplicar
          if (valorActual && valorActual.toString().trim() === ubicacion) {
            return { success: false, message: "Esta ubicación ya está asignada a este código" };
          }
          
          // Si está vacío y aún no encontramos campo disponible, usar este
          if (!campoDisponible && (!valorActual || valorActual.toString().trim() === '')) {
            campoDisponible = campo;
            colDisponible = colIndex;
          }
        }
        
        // 4. Si no hay campo disponible
        if (!campoDisponible) {
          return { 
            success: false, 
            message: "No hay campos de ubicación disponibles (máximo 5 ubicaciones)" 
          };
        }
        
        // 5. Actualizar el campo disponible
        inventarioSheet.getRange(filaEncontrada + 1, colDisponible + 1).setValue(ubicacion);
        
        // Registrar la acción
        intrusosSheet.appendRow([
          ubicacion,
          cleanInfo.clean,
          "AGREGADO",
          usuario,
          new Date().toLocaleString("es-PA"),
          `Intruso validado y agregado en ${campoDisponible}`
        ]);
        
        clearCacheInventario();
        return { 
          success: true, 
          message: `Código agregado en ${campoDisponible}` 
        };
        
      case "MARCAR_VALIDO":
        // Solo marcar como válido sin agregar
        intrusosSheet.appendRow([
          ubicacion,
          codigo,
          "MARCADO_VALIDO",
          usuario,
          new Date().toLocaleString("es-PA"),
          "Intruso marcado como válido (no se modificó inventario)"
        ]);
        return { success: true, message: "Intruso marcado como válido" };
        
      case "IGNORAR":
        // Ignorar el intruso
        intrusosSheet.appendRow([
          ubicacion,
          codigo,
          "IGNORADO",
          usuario,
          new Date().toLocaleString("es-PA"),
          "Intruso ignorado"
        ]);
        return { success: true, message: "Intruso ignorado" };
        
      default:
        return { success: false, message: "Acción no válida" };
    }
  } catch (error) {
    return { success: false, message: error.toString() };
  }
}

function verificarSiIntrusoEsValido(ubicacion, codigo) {
  try {
    const sm = new SheetManager();
