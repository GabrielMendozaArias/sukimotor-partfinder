function obtenerUsuarioPorEmail(email) {
  try {
    Logger.log("=== INICIO obtenerUsuarioPorEmail ===");
    Logger.log("Email buscado: " + email);
    
    // Validación de entrada
    if (!email || typeof email !== 'string' || email.trim() === '') {
      Logger.log("ERROR: Email inválido");
      return { 
        success: false, 
        message: "Email inválido",
        data: null 
      };
    }
    
    const sm = new SheetManager();
    const usuariosSheet = sm.ss.getSheetByName("Usuarios");
    
    if (!usuariosSheet) {
      Logger.log("ERROR: Hoja Usuarios no encontrada");
      return { 
        success: false, 
        message: "Hoja de usuarios no encontrada",
        data: null 
      };
    }
    
    const datos = usuariosSheet.getDataRange().getValues();
    Logger.log("Total filas: " + datos.length);
    
    if (datos.length <= 1) {
      Logger.log("ERROR: No hay usuarios");
      return { 
        success: false, 
        message: "No hay usuarios registrados",
        data: null 
      };
    }
    
    // Buscar el usuario
    const emailBuscar = email.toString().trim().toLowerCase();
    
    for (let i = 1; i < datos.length; i++) {
      const emailFila = datos[i][0];
      
      if (!emailFila) continue;
      
      if (emailFila.toString().trim().toLowerCase() === emailBuscar) {
        Logger.log(" Usuario encontrado en fila: " + (i + 1));
        
        // Parsear permisos
        let permisos = {
          buscar: false,
          ubicaciones: false,
          verificar: false,
          recepcion: false,
          auditoria: false,
          editar: false,
          dashboard: false,
          admin: false
        };
        
        try {
          const permisosStr = datos[i][5];
          if (permisosStr && typeof permisosStr === 'string') {
            permisos = JSON.parse(permisosStr);
          } else if (typeof permisosStr === 'object') {
            permisos = permisosStr;
          }
        } catch (e) {
          Logger.log(" Error parseando permisos: " + e);
        }
        
        // Normalizar activo
        const activoRaw = datos[i][6];
        const activo = activoRaw === true || 
                       activoRaw === "TRUE" || 
                       activoRaw === "true" ||
                       activoRaw === 1 ||
                       activoRaw === "1";
        
        const usuario = {
          email: datos[i][0].toString(),
          pin: datos[i][1] ? datos[i][1].toString() : "",
          rol: datos[i][4] ? datos[i][4].toString() : "Sin rol",
          permisos: permisos,
          activo: activo,
          fechaCreacion: datos[i][7] ? datos[i][7].toString() : "No disponible",
          ultimoAcceso: datos[i][8] ? datos[i][8].toString() : "Nunca"
        };
        
        Logger.log("Usuario preparado: " + JSON.stringify(usuario));
        Logger.log("=== FIN obtenerUsuarioPorEmail ===");
        
        return { 
          success: true, 
          data: usuario,
          message: "Usuario encontrado" 
        };
      }
    }
    
    Logger.log("❌ Usuario no encontrado: " + email);
    
    return { 
      success: false, 
      message: "Usuario no encontrado: " + email,
      data: null 
    };
    
  } catch (error) {
    Logger.log(" ERROR CRÍTICO: " + error.toString());
    Logger.log("Stack: " + error.stack);
    
    return { 
      success: false, 
      message: "Error del servidor: " + error.toString(),
      data: null,
      error: error.stack
    };
  }
}
function actualizarUsuario(datosActualizados) {
  try {
    Logger.log("=== INICIO actualizarUsuario ===");
    Logger.log("Datos recibidos: " + JSON.stringify(datosActualizados));
    
    // Validaciones
    if (!datosActualizados || !datosActualizados.email) {
      return { success: false, message: "Datos inválidos" };
    }
    
    const sm = new SheetManager();
    const usuariosSheet = sm.ss.getSheetByName("Usuarios");
    
    if (!usuariosSheet) {
      return { success: false, message: "Hoja no encontrada" };
    }
    
    const datos = usuariosSheet.getDataRange().getValues();
    let filaUsuario = -1;
    
    // Buscar la fila del usuario
    const emailBuscar = datosActualizados.email.toString().trim().toLowerCase();
    
    for (let i = 1; i < datos.length; i++) {
      if (datos[i][0] && datos[i][0].toString().trim().toLowerCase() === emailBuscar) {
        filaUsuario = i + 1;
        Logger.log(" Usuario encontrado en fila: " + filaUsuario);
        break;
      }
    }
    
    if (filaUsuario === -1) {
      Logger.log("❌ Usuario no encontrado");
      return { success: false, message: "Usuario no encontrado" };
    }
    
    // Actualizar Rol (columna 5)
    if (datosActualizados.rol) {
      usuariosSheet.getRange(filaUsuario, 5).setValue(datosActualizados.rol);
      Logger.log(" Rol actualizado: " + datosActualizados.rol);
    }
    
    // Actualizar Permisos (columna 6)
    if (datosActualizados.permisos) {
      const permisosStr = JSON.stringify(datosActualizados.permisos);
      usuariosSheet.getRange(filaUsuario, 6).setValue(permisosStr);
      Logger.log(" Permisos actualizados: " + permisosStr);
    }
    
    // Actualizar Estado Activo (columna 7)
    // ⭐ CONVERSIÓN ROBUSTA A BOOLEANO
    let activo = false;
    if (datosActualizados.activo === true || 
        datosActualizados.activo === "true" || 
        datosActualizados.activo === 1 || 
        datosActualizados.activo === "1") {
      activo = true;
    }
    
    usuariosSheet.getRange(filaUsuario, 7).setValue(activo);
    Logger.log(" Estado activo actualizado: " + activo);
    
    // Actualizar PIN si se proporcionó uno nuevo
    if (datosActualizados.nuevoPin && datosActualizados.nuevoPin.trim() !== '') {
      const { hash, salt } = hashPIN(datosActualizados.nuevoPin);
      
      usuariosSheet.getRange(filaUsuario, 2).setValue(datosActualizados.nuevoPin);
      usuariosSheet.getRange(filaUsuario, 3).setValue(hash);
      usuariosSheet.getRange(filaUsuario, 4).setValue(salt);
      
      Logger.log(" PIN actualizado");
    }
    
    Logger.log("=== FIN actualizarUsuario - ÉXITO ===");
    return { success: true, message: "Usuario actualizado correctamente" };
    
  } catch (error) {
    Logger.log(" ERROR CRÍTICO: " + error.toString());
    Logger.log("Stack: " + error.stack);
    
    return { 
      success: false, 
      message: "Error al actualizar: " + error.toString(),
      error: error.stack
    };
  }
}
