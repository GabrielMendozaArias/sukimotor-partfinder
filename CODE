function buscarPorUbicacion(ubicacion) {
  //  NORMALIZAR LA UBICACIÓN ESCANEADA
  const ubicacionInfo = normalizarUbicacion(ubicacion);
  const ubicacionNormalizada = ubicacionInfo.normalized;
  
  Logger.log(` Buscando ubicación: ${ubicacion} → ${ubicacionNormalizada}`);
  
  const sm = new SheetManager();
  const inventario = getCachedInventario();
  
  const resultados = inventario.filter(row => {
    // Normalizar también las ubicaciones del inventario para comparar
    const ub1 = normalizarUbicacionSimple(row['Ubicación Principal'] || "");
    const ub2 = normalizarUbicacionSimple(row['Ubicación 2'] || "");
    const ub3 = normalizarUbicacionSimple(row['Ubicación 3'] || "");
    const ub4 = normalizarUbicacionSimple(row['Ubicación 4'] || "");
    const ub5 = normalizarUbicacionSimple(row['Ubicación 5'] || "");
    
    return ub1 === ubicacionNormalizada || 
           ub2 === ubicacionNormalizada || 
           ub3 === ubicacionNormalizada ||
           ub4 === ubicacionNormalizada ||
           ub5 === ubicacionNormalizada;
  });

  return {
    ubicacion: ubicacionNormalizada, // Devolver la versión normalizada
    ubicacionOriginal: ubicacion,
    resultados: resultados,
    count: resultados.length,
    normalizado: ubicacionInfo.info
  };
}

