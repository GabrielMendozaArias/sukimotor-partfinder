function enviarReporteDiarioVerificaciones() {
  try {
    const sm = new SheetManager();
    const verificacionesSheet = sm.ss.getSheetByName("Verificaciones");
    
    if (!verificacionesSheet) {
      return { success: false, message: "Hoja de verificaciones no encontrada" };
    }
    
    // Obtener verificaciones de hoy
    const hoy = new Date();
    const inicioHoy = new Date(hoy.getFullYear(), hoy.getMonth(), hoy.getDate(), 0, 0, 0);
    const finHoy = new Date(hoy.getFullYear(), hoy.getMonth(), hoy.getDate(), 23, 59, 59);
    
    const datos = verificacionesSheet.getDataRange().getValues();
    const verificacionesHoy = [];
    
    for (let i = 1; i < datos.length; i++) {
      const fechaStr = datos[i][0];
      const fecha = new Date(fechaStr);
      
      if (fecha >= inicioHoy && fecha <= finHoy) {
        verificacionesHoy.push({
          fecha: fechaStr,
          ubicacion: datos[i][1],
          validados: datos[i][2],
          intrusos: datos[i][3],
          ausentes: datos[i][4],
          tasaExito: datos[i][5],
          usuario: datos[i][6],
          detalles: datos[i][7]
        });
      }
    }
    
    if (verificacionesHoy.length === 0) {
      return { success: true, message: "No hay verificaciones hoy", enviados: 0 };
    }
    
    // Generar HTML del reporte
    const htmlReporte = generarHTMLReporteDiario(verificacionesHoy, hoy);
    
    // Enviar email
    const emailMgr = new EmailManagerRobusto(sm);
    const resultado = emailMgr.enviarReporte(
      "DIARIO",
      {
        id: "DAILY-" + Date.now(),
        fechaGeneracion: new Date().toLocaleString("es-PA")
      },
