/**
 * Parsear fechas en formato "10/31/2025, 3:40:28 p. m."
 * Maneja strings con a.m./p.m., objetos Date y números de Excel
 */
function parseFechaLocal(fechaStr) {
  if (!fechaStr) return null;
  
  try {
    // Si ya es un objeto Date, usarlo directamente
    if (typeof fechaStr === 'object' && fechaStr instanceof Date) {
      const fecha = new Date(fechaStr.getTime());
      fecha.setHours(0, 0, 0, 0);
      return fecha;
    }
    
    // Si es número (serial de Excel)
    if (typeof fechaStr === 'number') {
      const fecha = new Date((fechaStr - 25569) * 86400 * 1000);
      fecha.setHours(0, 0, 0, 0);
      return fecha;
    }
    
    // Si es string, limpiar y parsear
    if (typeof fechaStr === 'string') {
      // Remover "a. m." y "p. m." que causan problemas en español
      let fechaLimpia = fechaStr.toString()
        .replace(/\s*a\.\s*m\./gi, ' AM')
        .replace(/\s*p\.\s*m\./gi, ' PM')
        .trim();
      
      const fecha = new Date(fechaLimpia);
      
      // Validar que la fecha es válida
      if (isNaN(fecha.getTime())) {
        return null;
      }
      
      fecha.setHours(0, 0, 0, 0);
      return fecha;
    }
    
    return null;
    
  } catch (error) {
    Logger.log(` Error parseando fecha: ${error.message}`);
    return null;
  }
}

