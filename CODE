//  NORMALIZACIÓN DE UBICACIONES
// ========================================

/**
 * Normaliza códigos de ubicación al formato estándar: ZONA-PASILLO-ANAQUEL-RACK-NIVEL
 * Ejemplo: B1A01F → B-1-A-01-F
 *          B-1-A-01-F → B-1-A-01-F (ya normalizado)
 */
function normalizarUbicacion(ubicacionRaw) {
  if (!ubicacionRaw || typeof ubicacionRaw !== 'string') {
    return { normalized: "", isValid: false, info: "Entrada inválida" };
  }

  let ubicacion = ubicacionRaw.trim().toUpperCase();
  
  // Convertir comillas simples a guiones (por si acaso)
  ubicacion = ubicacion.replace(/'/g, '-');
  
  // Si ya tiene guiones en el formato correcto, validar y devolver
  const patternConGuiones = /^([A-Z])-(\d+)-([A-Z])-(\d+)-([A-Z])$/;
  const matchConGuiones = ubicacion.match(patternConGuiones);
  
  if (matchConGuiones) {
    // Ya está en formato correcto, solo asegurar que rack tenga 2 dígitos
    const zona = matchConGuiones[1];
    const pasillo = matchConGuiones[2];
    const anaquel = matchConGuiones[3];
    const rack = matchConGuiones[4].padStart(2, '0');
    const nivel = matchConGuiones[5];
    
    return {
      normalized: `${zona}-${pasillo}-${anaquel}-${rack}-${nivel}`,
      isValid: true,
      info: "Formato correcto",
      partes: { zona, pasillo, anaquel, rack, nivel }
    };
  }
  
  // Remover guiones y espacios para procesar texto plano
  const textoLimpio = ubicacion.replace(/[-\s]/g, '');
  
  // Patrón para texto sin guiones: LETRA + NÚMEROS + LETRA + NÚMEROS + LETRA
  // Ejemplo: B1A01F, B12C05A, A1A1A
  const patternSinGuiones = /^([A-Z])(\d+)([A-Z])(\d+)([A-Z])$/;
  const matchSinGuiones = textoLimpio.match(patternSinGuiones);
  
  if (matchSinGuiones) {
    const zona = matchSinGuiones[1];
    const pasillo = matchSinGuiones[2];
    const anaquel = matchSinGuiones[3];
    const rack = matchSinGuiones[4].padStart(2, '0'); // Asegurar 2 dígitos
    const nivel = matchSinGuiones[5];
    
    const normalized = `${zona}-${pasillo}-${anaquel}-${rack}-${nivel}`;
    
    Logger.log(` Ubicación normalizada: ${ubicacionRaw} → ${normalized}`);
    
    return {
      normalized: normalized,
      isValid: true,
      info: "Normalizado desde texto plano",
      partes: { zona, pasillo, anaquel, rack, nivel }
    };
  }
  
  // Si no coincide con ningún patrón, intentar devolver limpio
  Logger.log(` Ubicación no reconocida: ${ubicacionRaw}`);
  
  return {
    normalized: ubicacion,
    isValid: false,
    info: "Formato no reconocido. Use: B1A01F o B-1-A-01-F",
    partes: null
  };
}

/**
 * Versión simplificada que solo devuelve el string normalizado
 */
function normalizarUbicacionSimple(ubicacionRaw) {
  const resultado = normalizarUbicacion(ubicacionRaw);
  return resultado.normalized;
}
