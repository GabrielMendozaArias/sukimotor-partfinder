// ========================================
//  PROCESAR IMAGEN DE ORDEN CON GEMINI
// ========================================
function procesarImagenOrden(imagenBase64) {
  try {
    // Obtener API Key
    const apiKey = obtenerAPIKeyGemini();
    
    if (!apiKey) {
      return {
        success: false,
        error: "API Key de Gemini no configurada en Properties"
      };
    }

    // Limpiar base64 (quitar prefijo data:image/...)
    let base64Data = imagenBase64;
    if (imagenBase64.includes(',')) {
      base64Data = imagenBase64.split(',')[1];
    }

    //  USAR EL MODELO CORRECTO DE TU CONFIG
    const modelo = GEMINI_CONFIG.MODEL; // "gemini-2.0-flash"
    const url = `${GEMINI_CONFIG.API_ENDPOINT}/${modelo}:generateContent?key=${apiKey}`;

    // Prompt optimizado
    const prompt = `
Analiza esta imagen de una orden de compra o lista de repuestos automotrices.

TAREA:
Extrae TODOS los códigos de repuestos visibles en la imagen.
Para cada código, identifica también la cantidad solicitada.

FORMATO DE RESPUESTA (solo JSON válido, sin texto adicional):
{
  "items": [
    {"codigo": "E-10W40", "cantidad": 1, "descripcion": "ACEITE"},
    {"codigo": "16510-26H00-000", "cantidad": 1, "descripcion": "FILTRO"}
  ]
}

REGLAS:
- Si no ves cantidad, usa 1 por defecto
- Incluye TODOS los códigos que veas
- La descripción es opcional pero útil
- Devuelve SOLO el JSON, sin markdown ni explicaciones
`;

    // Preparar payload para Gemini
    const payload = {
      contents: [{
        parts: [
          { text: prompt },
          {
            inline_data: {
              mime_type: "image/jpeg",
              data: base64Data
            }
          }
        ]
      }],
      generationConfig: {
        temperature: 0.1,
        topK: 32,
        topP: 1,
        maxOutputTokens: 2048
      }
    };

    const options = {
      method: 'post',
      contentType: 'application/json',
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    };

    Logger.log(" Llamando a Gemini API...");
    const response = UrlFetchApp.fetch(url, options);
    const responseCode = response.getResponseCode();
    const responseText = response.getContentText();

    // Verificar código de respuesta
    if (responseCode !== 200) {
      Logger.log("❌ Error HTTP " + responseCode + ": " + responseText);
      return {
        success: false,
        error: `Error ${responseCode}: ${responseText.substring(0, 200)}`
      };
    }

    // Parsear respuesta
    const result = JSON.parse(responseText);
    
    if (!result.candidates || !result.candidates[0] || !result.candidates[0].content) {
      Logger.log("❌ Respuesta sin candidates");
      return {
        success: false,
        error: "Gemini no devolvió resultados. La imagen podría no ser clara."
      };
    }

    // Extraer texto de la respuesta
    const textoRespuesta = result.candidates[0].content.parts[0].text;
    Logger.log(" Respuesta Gemini: " + textoRespuesta);

    // Limpiar markdown si existe
    let jsonText = textoRespuesta
      .replace(/```json\n?/gi, '')
      .replace(/```\n?/g, '')
      .trim();

    // Parsear JSON
    let datos;
    try {
      datos = JSON.parse(jsonText);
    } catch (parseError) {
      Logger.log("❌ Error parsing JSON: " + parseError);
      Logger.log("Texto recibido: " + jsonText);
      return {
        success: false,
        error: "Gemini devolvió un formato inválido. Intenta con otra imagen más clara."
      };
    }

    // Validar que tenga items
    if (!datos.items || !Array.isArray(datos.items) || datos.items.length === 0) {
      return {
        success: false,
        error: "No se encontraron códigos en la imagen. Verifica que la imagen sea legible."
      };
    }

    Logger.log(` Se extrajeron ${datos.items.length} items`);
    
    return {
      success: true,
      items: datos.items
    };

  } catch (error) {
    Logger.log(" Error general: " + error.toString());
    Logger.log("Stack: " + error.stack);
    return {
      success: false,
      error: "Error interno: " + error.toString()
    };
  }
}

/**
 * Validar items contra inventario y agregar ubicaciones
 */
function validarItemsDespacho(items) {
  try {
    const inventario = getCachedInventario();
    const resultado = [];
    
    items.forEach(item => {
      const codigoLimpio = limpiarCodigo(item.codigo);
      
      // Buscar en inventario
      const itemInventario = inventario.find(inv => {
        const codigoInv = limpiarCodigo(inv['Código']);
        return codigoInv === codigoLimpio;
      });
      
      if (itemInventario) {
        // Encontrado - agregar ubicaciones
        const ubicaciones = [];
        if (itemInventario['Ubicación Principal']) ubicaciones.push(itemInventario['Ubicación Principal']);
        if (itemInventario['Ubicación 2']) ubicaciones.push(itemInventario['Ubicación 2']);
        if (itemInventario['Ubicación 3']) ubicaciones.push(itemInventario['Ubicación 3']);
        if (itemInventario['Ubicación 4']) ubicaciones.push(itemInventario['Ubicación 4']);
        if (itemInventario['Ubicación 5']) ubicaciones.push(itemInventario['Ubicación 5']);
        
        resultado.push({
          cantidad: item.cantidad || 1,
          codigo: item.codigo,
          codigoLimpio: codigoLimpio,
          descripcionOrden: item.descripcion || '',
          descripcionInventario: itemInventario['Descripción'] || '',
          marca: itemInventario['Marca'] || '',
          ubicaciones: ubicaciones,
          ubicacionPrincipal: ubicaciones[0] || 'SIN UBICACIÓN',
          encontrado: true,
          recogido: false
        });
      } else {
        // No encontrado
        resultado.push({
          cantidad: item.cantidad || 1,
          codigo: item.codigo,
          codigoLimpio: codigoLimpio,
          descripcionOrden: item.descripcion || '',
          encontrado: false,
          recogido: false,
          motivo: 'No existe en inventario'
        });
      }
    });
    
    // Ordenar por ubicación
    resultado.sort((a, b) => {
      if (!a.encontrado) return 1;
      if (!b.encontrado) return -1;
      return (a.ubicacionPrincipal || '').localeCompare(b.ubicacionPrincipal || '');
    });
    
    return {
      success: true,
      items: resultado,
      resumen: {
        total: resultado.length,
        encontrados: resultado.filter(i => i.encontrado).length,
        noEncontrados: resultado.filter(i => !i.encontrado).length
      }
    };
    
  } catch (error) {
    Logger.log("❌ Error en validarItemsDespacho: " + error);
    return {
      success: false,
      error: error.toString()
    };
  }
}

/**
 * Guardar despacho completado
 */
function guardarDespacho(datosDespacho) {
  try {
    const sm = new SheetManager();
    const usuario = Session.getActiveUser().getEmail();
    const timestamp = new Date();
    
    // Crear ID único
    const id = `DESP-${Utilities.formatDate(timestamp, 'GMT-5', 'yyyyMMdd-HHmmss')}`;
    
    // Preparar datos para guardar
    const registro = {
      'ID': id,
      'Fecha': Utilities.formatDate(timestamp, 'GMT-5', 'yyyy-MM-dd HH:mm:ss'),
      'Cliente': datosDespacho.cliente || 'N/A',
      'PO': datosDespacho.po || 'N/A',
      'Almacenista': usuario,
      'Total Items': datosDespacho.items.length,
      'Encontrados': datosDespacho.items.filter(i => i.encontrado).length,
      'No Encontrados': datosDespacho.items.filter(i => !i.encontrado).length,
      'Despachados': datosDespacho.items.filter(i => i.recogido).length,
      'Tiempo (min)': datosDespacho.tiempoTotal || 0,
      'Estado': 'Completado'
    };
    
    // Guardar en hoja "Despachos" (crear si no existe)
    const sheetName = 'Despachos';
    let sheet = SS.getSheetByName(sheetName);
    
    if (!sheet) {
      sheet = SS.insertSheet(sheetName);
      sheet.appendRow(Object.keys(registro));
    }
    
    sheet.appendRow(Object.values(registro));
    
    // Guardar detalle de items en hoja "Despachos_Detalle"
    const detalleSheet = SS.getSheetByName('Despachos_Detalle') || 
                         SS.insertSheet('Despachos_Detalle');
    
    if (detalleSheet.getLastRow() === 0) {
      detalleSheet.appendRow(['ID Despacho', 'Código', 'Cantidad', 'Descripción', 'Ubicación', 'Encontrado', 'Recogido']);
    }
    
    datosDespacho.items.forEach(item => {
      detalleSheet.appendRow([
        id,
        item.codigo,
        item.cantidad,
        item.descripcionInventario || item.descripcionOrden,
        item.ubicacionPrincipal || 'N/A',
        item.encontrado ? 'Sí' : 'No',
        item.recogido ? 'Sí' : 'No'
      ]);
    });
    
    return {
      success: true,
      id: id,
      message: 'Despacho guardado correctamente'
    };
    
  } catch (error) {
    Logger.log("❌ Error en guardarDespacho: " + error);
    return {
      success: false,
      error: error.toString()
    };
  }
}

/**
 * Obtener historial de despachos
 */
function obtenerHistorialDespachos(limite = 20) {
  try {
    const sheet = SS.getSheetByName('Despachos');
    
    if (!sheet || sheet.getLastRow() <= 1) {
      return {
        success: true,
        despachos: []
      };
    }
    
    const data = sheet.getDataRange().getValues();
    const headers = data[0];
    const rows = data.slice(1).reverse().slice(0, limite);
    
    const despachos = rows.map(row => {
      const obj = {};
      headers.forEach((header, index) => {
        obj[header] = row[index];
      });
      return obj;
    });
    
    return {
      success: true,
      despachos: despachos
    };
    
  } catch (error) {
    return {
      success: false,
      error: error.toString()
    };
  }
}

/**
 * Función auxiliar para limpiar código
 */
function limpiarCodigo(codigo) {
  if (!codigo) return '';
  return codigo.toString()
    .toUpperCase()
    .replace(/\s+/g, '')
    .replace(/[^A-Z0-9\-]/g, '')
    .trim();
}

