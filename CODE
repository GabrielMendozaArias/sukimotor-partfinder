class SheetManager {
  constructor() {
    this.ss = SpreadsheetApp.openById(CONFIG.SHEET_ID);
    this.cache = CacheService.getScriptCache();
  }

  getOrCreateSheet(name, headers = []) {
    let sheet = this.ss.getSheetByName(name);
    if (!sheet) {
      sheet = this.ss.insertSheet(name);
      if (headers.length > 0) {
        sheet.appendRow(headers);
      }
    }
    return sheet;
  }

  initializeDatabase() {
    const sheets = [
      { name: "Inventario", headers: ["Código", "Descripción", "Marca", "Ubicación Principal", "Ubicación 2", "Ubicación 3", "Ubicación 4", "Ubicación 5", "Último Inventario"] },
      { name: "Ubicaciones", headers: ["Ubicación", "ID", "Zona", "Pasillo", "Anaquel", "Rack", "Nivel", "Estado"] },
      { name: "Usuarios", headers: ["Email", "PIN", "Hash", "Salt", "Rol", "Permisos", "Activo", "FechaCreacion", "UltimoAcceso"] },
      { name: "Verificaciones", headers: ["Fecha", "Ubicación", "Validados", "Intrusos", "Ausentes", "Tasa_Éxito", "Usuario", "Detalles"] },
      { name: "Auditorias", headers: ["ID", "Código", "Estado", "Cantidad", "Fecha", "Usuario", "Notas", "Fotos"] },
      { name: "Recepciones", headers: ["ID", "Factura", "Código", "Cantidad", "Fecha", "Usuario", "UbicacionAsignada", "Estado"] },
      { name: "Logs", headers: ["Timestamp", "Usuario", "Acción", "Detalles", "Estado"] },
      { name: "Items_Eliminados", headers: ["Código", "Descripción", "Marca", "FechaEliminacion", "Usuario", "Motivo"] },
      { name: "ConteosFisicos", headers: ["Fecha","Ubicación","Esperados","Contados","Ausentes","NoEsperados","TasaCobertura","Usuario","Detalles","ID"] },
      { name: "ConteoFisico_Lotes", headers: ["LoteID", "Código", "Descripción", "Marca", "Ubicación", "CantSistema", "CantFísica", "Defectuoso", "Faltante", "Sobrante", "Fotos", "FechaCierre", "Estado", "Usuario", "Timestamp"] }
    ];

    sheets.forEach(sheetConfig => {
      this.getOrCreateSheet(sheetConfig.name, sheetConfig.headers);
    });

    this.createDefaultUsers();
  }

  createDefaultUsers() {
    const usuariosSheet = this.getOrCreateSheet("Usuarios");
    const datos = usuariosSheet.getDataRange().getValues();
    
    if (datos.length === 1) {
      const { hash, salt } = hashPIN("1234");
      usuariosSheet.appendRow([
        "admin@suz.com.pa",
        "1234",
        hash,
        salt,
        "Admin",
        JSON.stringify({ buscar: true, ubicaciones: true, verificar: true, recepcion: true, auditoria: true, editar: true, dashboard: true, admin: true }),
        true,
        new Date().toLocaleString("es-PA"),
        ""
      ]);
    }
  }

  getInventarioData() {
    const sheet = this.ss.getSheetByName("Inventario");
    const datos = sheet.getDataRange().getValues();
    const headers = datos[0];
    const registros = datos.slice(1).map(row => {
      let obj = {};
      headers.forEach((header, i) => {
        obj[header] = row[i] || "";
      });
      return obj;
    });
    return registros;
  }

  getUbicacionesData() {
    const sheet = this.ss.getSheetByName("Ubicaciones");
    if (!sheet) return [];
    
    const datos = sheet.getDataRange().getValues();
    const headers = datos[0];
    return datos.slice(1).map(row => {
      let obj = {};
      headers.forEach((header, i) => {
        obj[header] = row[i] || "";
      });
      return obj;
    });
  }

  searchInventario(term, fieldIndex = 0) {
    const inventario = getCachedInventario();
    const headers = ["Código", "Descripción", "Marca", "Ubicación Principal", "Ubicación 2", "Ubicación 3"];
    
    term = term.toString().toUpperCase();
    const fieldName = headers[fieldIndex];
    
    return inventario.filter(item => {
      const fieldValue = (item[fieldName] || "").toString().toUpperCase();
      return fieldValue.includes(term);
    });
  }

  updateRecord(sheetName, searchField, searchValue, updateData) {
    const sheet = this.getOrCreateSheet(sheetName);
    const datos = sheet.getDataRange().getValues();
    const headers = datos[0];
    
    for (let i = 1; i < datos.length; i++) {
      let fieldIndex = headers.indexOf(searchField);
      if (fieldIndex !== -1 && datos[i][fieldIndex].toString().toUpperCase() === searchValue.toUpperCase()) {
        Object.keys(updateData).forEach(key => {
          const colIndex = headers.indexOf(key);
          if (colIndex !== -1) {
            sheet.getRange(i + 1, colIndex + 1).setValue(updateData[key]);
          }
        });
        clearCacheInventario();
        return true;
      }
    }
    return false;
  }

  deleteRecord(sheetName, searchField, searchValue) {
    const sheet = this.ss.getSheetByName(sheetName);
    const datos = sheet.getDataRange().getValues();
    const headers = datos[0];
    
    for (let i = 1; i < datos.length; i++) {
      let fieldIndex = headers.indexOf(searchField);
      if (fieldIndex !== -1 && datos[i][fieldIndex].toString().toUpperCase() === searchValue.toUpperCase()) {
        sheet.deleteRow(i + 1);
        clearCacheInventario();
        return true;
      }
    }
    return false;
  }

  addRecord(sheetName, rowData) {
    const sheet = this.getOrCreateSheet(sheetName);
    sheet.appendRow(rowData);
    clearCacheInventario();
    return true;
  }
}

