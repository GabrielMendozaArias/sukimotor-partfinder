    for (let i = datos.length - 1; i >= 1; i--) {
      const fechaStr = datos[i][0];
      const fecha = new Date(fechaStr);
      
      if (fecha < hace90Dias) {
        filasAEliminar.push(i + 1); // +1 porque las filas en Sheets empiezan en 1
      }
    }
    
    // Eliminar filas (de abajo hacia arriba para no descuadrar índices)
    let eliminadas = 0;
    filasAEliminar.forEach(fila => {
      logsSheet.deleteRow(fila);
      eliminadas++;
    });
    
    return { 
      success: true, 
      eliminadas: eliminadas,
      message: `Se eliminaron ${eliminadas} logs mayores a 90 días`
    };
    
  } catch (error) {
    console.error("Error en limpieza de logs:", error);
    return { success: false, message: error.toString() };
  }
}

