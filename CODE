    // Buscar el código en inventario
    const inventario = getCachedInventario();
    const item = inventario.find(i => i['Código'].toString().toUpperCase() === cleanInfo.clean);
    
    if (!item) {
      return { success: false, message: "Código no encontrado: " + cleanInfo.clean };
    }
    
    // Determinar qué campo de ubicación usar
    let campoUbicacion = null;
    
    if (!item['Ubicación Principal'] || item['Ubicación Principal'].trim() === '') {
      campoUbicacion = "Ubicación Principal";
    } else if (!item['Ubicación 2'] || item['Ubicación 2'].trim() === '') {
      campoUbicacion = "Ubicación 2";
    } else if (!item['Ubicación 3'] || item['Ubicación 3'].trim() === '') {
      campoUbicacion = "Ubicación 3";
    } else if (!item['Ubicación 4'] || item['Ubicación 4'].trim() === '') {
      campoUbicacion = "Ubicación 4";
    } else if (!item['Ubicación 5'] || item['Ubicación 5'].trim() === '') {
      campoUbicacion = "Ubicación 5";
    } else {
      return { 
        success: false, 
        message: " Las 5 ubicaciones están ocupadas.", 
        requiereConsolidacion: true,
        ubicaciones: [
          item['Ubicación Principal'], 
          item['Ubicación 2'], 
          item['Ubicación 3'],
          item['Ubicación 4'],
          item['Ubicación 5']
        ]
      };
    }
    
    //  GUARDAR LA UBICACIÓN NORMALIZADA
    const success = sm.updateRecord("Inventario", "Código", cleanInfo.clean, { 
      [campoUbicacion]: ubicacionNormalizada 
    });
    
    if (success) {
      return { 
        success: true, 
        message: `Ubicación ${ubicacionNormalizada} asignada a ${campoUbicacion}`, 
        campo: campoUbicacion,
        ubicacionNormalizada: ubicacionNormalizada
      };
    } else {
      return { success: false, message: "Error al asignar ubicación" };
    }
  } catch (error) {
    return { success: false, message: error.toString() };
  }
}

function obtenerEstadisticasDashboard() {
  const inventario = getCachedInventario();
  const conUbicacion = inventario.filter(r => {
    const ubicacion = r['Ubicación Principal'];
    return ubicacion && typeof ubicacion === 'string' && ubicacion.trim() !== '';
  });
  const sinUbicacion = inventario.filter(r => {
    const ubicacion = r['Ubicación Principal'];
    return !ubicacion || typeof ubicacion !== 'string' || ubicacion.trim() === '';
  });
  
  return {
    totalRepuestos: inventario.length,
    conUbicacion: conUbicacion.length,
    sinUbicacion: sinUbicacion.length,
    porcentajeUbicados: inventario.length > 0 ? ((conUbicacion.length / inventario.length) * 100).toFixed(1) : 0
  };
}

function filtrarUbicaciones(filtros) {
  try {
    const sm = new SheetManager();
    const ubicacionesRaw = getCachedUbicaciones();
    
    // Validar que tenemos datos
    if (!ubicacionesRaw || !Array.isArray(ubicacionesRaw) || ubicacionesRaw.length === 0) {
      return { 
        success: true, 
        resultados: [], 
        count: 0,
        message: "No hay ubicaciones en la base de datos" 
      };
    }
    
    let resultados = [...ubicacionesRaw]; // Crear copia
    
    // Filtro por zona (requerido)
    if (filtros.zona) {
      resultados = resultados.filter(u => {
        const zona = (u['Zona'] || u.Zona || '').toString().toUpperCase();
        return zona === filtros.zona.toUpperCase();
      });
    }
    
    // Filtros opcionales
    if (filtros.pasillo) {
      resultados = resultados.filter(u => {
        const pasillo = (u['Pasillo'] || u.Pasillo || '').toString();
        return pasillo === filtros.pasillo.toString();
      });
    }
    
    if (filtros.anaquel) {
      resultados = resultados.filter(u => {
        const anaquel = (u['Anaquel'] || u.Anaquel || '').toString().toUpperCase();
        return anaquel === filtros.anaquel.toUpperCase();
      });
    }
    
    if (filtros.rack) {
      resultados = resultados.filter(u => {
        const rack = (u['Rack'] || u.Rack || '').toString();
        return rack === filtros.rack.toString();
      });
    }
    
    if (filtros.nivel) {
      resultados = resultados.filter(u => {
        const nivel = (u['Nivel'] || u.Nivel || '').toString().toUpperCase();
        return nivel === filtros.nivel.toUpperCase();
      });
    }
    
    if (filtros.estado) {
      resultados = resultados.filter(u => {
        const estado = (u['Estado'] || u.Estado || '').toString();
        return estado === filtros.estado;
      });
    }
    
    // Para cada ubicación, buscar códigos
    const inventario = getCachedInventario() || [];
    resultados = resultados.map(ub => {
      const ubicacionStr = (ub['Ubicación'] || ub.Ubicacion || '').toString().trim().toUpperCase();
      
      const codigos = inventario.filter(item => {
        const ub1 = (item['Ubicación Principal'] || '').toString().trim().toUpperCase();
        const ub2 = (item['Ubicación 2'] || '').toString().trim().toUpperCase();
        const ub3 = (item['Ubicación 3'] || '').toString().trim().toUpperCase();
        return ub1 === ubicacionStr || ub2 === ubicacionStr || ub3 === ubicacionStr;
      });
      
      return {
        Ubicacion: ubicacionStr,
        Zona: ub['Zona'] || ub.Zona,
        Pasillo: ub['Pasillo'] || ub.Pasillo,
        Anaquel: ub['Anaquel'] || ub.Anaquel,
        Rack: ub['Rack'] || ub.Rack,
        Nivel: ub['Nivel'] || ub.Nivel,
        Estado: ub['Estado'] || ub.Estado || 'Activa',
        codigos: codigos,
        cantidadCodigos: codigos.length
      };
    });
    
    return { success: true, resultados: resultados, count: resultados.length };
    
  } catch (error) {
    console.error("Error en filtrarUbicaciones:", error);
    return { 
      success: false, 
      message: error.toString(),
      resultados: [],
      count: 0
    };
  }
}
/**
 * Elimina una ubicación específica de un código sin afectar las otras
 */
function eliminarUbicacionEspecifica(codigo, ubicacionAEliminar) {
  try {
    const ss = SpreadsheetApp.openById(CONFIG.SHEET_ID);
    const sheet = ss.getSheetByName('Inventario');
    const data = sheet.getDataRange().getValues();
    
    // Índices de columnas
    const COL_CODIGO = 0;
    const COL_UBICACION_1 = 3;
    const COL_UBICACION_2 = 4;
    const COL_UBICACION_3 = 5;
    const COL_UBICACION_4 = 6;
    const COL_UBICACION_5 = 7;
    
    // Buscar el código
    for (let i = 1; i < data.length; i++) {
      const codigoEnSheet = String(data[i][COL_CODIGO] || '').trim();
      
      if (codigoEnSheet === codigo) {
        // Obtener las 5 ubicaciones
        let ubicacion1 = String(data[i][COL_UBICACION_1] || '').trim();
        let ubicacion2 = String(data[i][COL_UBICACION_2] || '').trim();
        let ubicacion3 = String(data[i][COL_UBICACION_3] || '').trim();
        let ubicacion4 = String(data[i][COL_UBICACION_4] || '').trim();
        let ubicacion5 = String(data[i][COL_UBICACION_5] || '').trim();
        
        // Array de ubicaciones para facilitar el manejo
        let ubicaciones = [ubicacion1, ubicacion2, ubicacion3, ubicacion4, ubicacion5];
        
        // Encontrar y eliminar la ubicación específica
        const indice = ubicaciones.indexOf(ubicacionAEliminar);
        
        if (indice === -1) {
          return { exito: false, mensaje: `El código ${codigo} no tiene la ubicación ${ubicacionAEliminar}` };
        }
        
        // Eliminar la ubicación y reorganizar
        ubicaciones.splice(indice, 1);
        ubicaciones.push(''); // Agregar un espacio vacío al final
        
        // Actualizar las celdas
        sheet.getRange(i + 1, COL_UBICACION_1 + 1).setValue(ubicaciones[0]);
        sheet.getRange(i + 1, COL_UBICACION_2 + 1).setValue(ubicaciones[1]);
        sheet.getRange(i + 1, COL_UBICACION_3 + 1).setValue(ubicaciones[2]);
        sheet.getRange(i + 1, COL_UBICACION_4 + 1).setValue(ubicaciones[3]);
        sheet.getRange(i + 1, COL_UBICACION_5 + 1).setValue(ubicaciones[4]);
        
        Logger.log(`✓ Eliminada ubicación ${ubicacionAEliminar} del código ${codigo}`);
        return { exito: true, mensaje: `Ubicación eliminada de ${codigo}` };
      }
    }
    
    return { exito: false, mensaje: `Código ${codigo} no encontrado` };
    
  } catch (error) {
    Logger.log('Error en eliminarUbicacionEspecifica: ' + error);
    return { exito: false, mensaje: 'Error: ' + error.message };
  }
}
