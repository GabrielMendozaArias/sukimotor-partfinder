function obtenerUsuarios() {
  try {
    Logger.log("=== INICIO obtenerUsuarios ===");
    
    const sm = new SheetManager();
    const usuariosSheet = sm.ss.getSheetByName("Usuarios");
    
    if (!usuariosSheet) {
      Logger.log("❌ ERROR: Hoja Usuarios no encontrada");
      return { 
        success: false, 
        message: "La hoja 'Usuarios' no existe",
        usuarios: []
      };
    }
    
    const datos = usuariosSheet.getDataRange().getValues();
    Logger.log("Total de filas: " + datos.length);
    
    if (datos.length <= 1) {
      Logger.log(" No hay usuarios");
      return { 
        success: true, 
        usuarios: [],
        message: "No hay usuarios registrados"
      };
    }
    
    const usuarios = [];
    
    for (let i = 1; i < datos.length; i++) {
      const row = datos[i];
      
      // Saltar filas vacías
      if (!row[0]) continue;
      
      // Normalizar campo activo
      const activoRaw = row[6];
      const activo = activoRaw === true || 
                     activoRaw === "TRUE" || 
                     activoRaw === "true" ||
                     activoRaw === 1 ||
                     activoRaw === "1";
      
      usuarios.push({
        email: row[0].toString(),
        rol: row[4] ? row[4].toString() : "Sin rol",
        activo: activo,
        ultimoAcceso: row[8] ? row[8].toString() : "Nunca"
      });
    }
    
    Logger.log(" Total usuarios: " + usuarios.length);
    
    const resultado = { 
      success: true, 
      usuarios: usuarios,
      message: "OK"
    };
    
    Logger.log("=== FIN obtenerUsuarios - Retornando: " + JSON.stringify(resultado));
    
    return resultado;
    
  } catch (error) {
    Logger.log(" ERROR CRÍTICO: " + error.toString());
    Logger.log("Stack: " + error.stack);
    
    return { 
      success: false, 
      message: error.toString(),
      usuarios: [],
      error: error.stack
    };
  }
}

