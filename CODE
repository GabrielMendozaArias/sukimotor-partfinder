/**
 * Guardar auditoría con reporte completo
 */
function guardarAuditoriaCompleta(datosAuditoria) {
  try {
    Logger.log("=== INICIO guardarAuditoriaCompleta ===");
    Logger.log("Datos recibidos: " + JSON.stringify({
      codigo: datosAuditoria.codigo,
      estado: datosAuditoria.estado,
      cantidad: datosAuditoria.cantidad,
      tieneNotas: !!datosAuditoria.notas,
      cantidadFotos: datosAuditoria.fotos ? datosAuditoria.fotos.length : 0
    }));
    
    const sm = new SheetManager();
    const sheet = sm.getOrCreateSheet("Auditorias");
    const session = getSessionUser(datosAuditoria.sessionId);
    
    if (!session.success) {
      return { success: false, message: "Sesión inválida" };
    }
    
    const cleanInfo = cleanPartCode(datosAuditoria.codigo);
    const idAuditoria = "AUD-" + Utilities.formatDate(new Date(), "GMT-5", "yyyyMMdd-HHmmss");
    const timestamp = new Date().toLocaleString("es-PA");
    
    // 1⃣ Buscar información del código en inventario
    const inventario = getCachedInventario();
    const itemInventario = inventario.find(i => 
      i['Código'].toString().toUpperCase() === cleanInfo.clean.toUpperCase()
    );
    
    const descripcion = itemInventario ? itemInventario['Descripción'] : 'No encontrado en inventario';
    const marca = itemInventario ? itemInventario['Marca'] : 'Desconocida';
    const ubicacion = itemInventario ? itemInventario['Ubicación Principal'] : 'Sin ubicación';
    
    // 2⃣ Crear estructura de carpetas organizada
    const carpetas = obtenerCarpetaReportes("Auditorias", idAuditoria);
    
    if (!carpetas.success) {
      Logger.log(" Error creando carpetas, continuando sin Drive");
    }
    
    // 3⃣ Subir fotos a la carpeta específica
    let urlFotos = [];
    let fotosProcesadas = [];
    
    if (datosAuditoria.fotos && datosAuditoria.fotos.length > 0 && carpetas.success) {
      Logger.log(` Procesando ${datosAuditoria.fotos.length} fotos...`);
      
      datosAuditoria.fotos.forEach((fotoData, index) => {
        try {
          // Limpiar base64
          let base64Data = fotoData;
          if (fotoData.includes(',')) {
            base64Data = fotoData.split(',')[1];
          }
          
          const blob = Utilities.newBlob(
            Utilities.base64Decode(base64Data), 
            'image/jpeg', 
            `${idAuditoria}_foto${index + 1}.jpg`
          );
          
          const archivo = carpetas.carpetaReporte.createFile(blob);
          archivo.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
          
          urlFotos.push(archivo.getUrl());
          fotosProcesadas.push({
            nombre: archivo.getName(),
            url: archivo.getUrl(),
            id: archivo.getId()
          });
          
          Logger.log(` Foto ${index + 1} subida: ${archivo.getName()}`);
          
        } catch (fotoError) {
          Logger.log(`❌ Error subiendo foto ${index + 1}: ${fotoError}`);
        }
      });
    }
    
    // 4⃣ Preparar datos completos de la auditoría
    const datosCompletos = {
      id: idAuditoria,
      codigo: cleanInfo.clean,
      descripcion: descripcion,
      marca: marca,
      ubicacion: ubicacion,
      estado: datosAuditoria.estado,
      cantidad: datosAuditoria.cantidad || "N/A",
      notas: datosAuditoria.notas || "",
      usuario: session.user.email,
      fecha: timestamp,
      fotos: fotosProcesadas,
      carpetaDrive: carpetas.success ? carpetas.rutaCompleta : "No disponible"
    };
    
    // 5⃣ Generar reporte PDF
    let urlReporte = "";
    if (carpetas.success) {
      urlReporte = generarReporteAuditoriaPDF(datosCompletos, carpetas.carpetaReporte);
    }
    
    // 6⃣ Guardar en hoja de cálculo
    sheet.appendRow([
      idAuditoria,
      cleanInfo.clean,
      datosAuditoria.estado,
      datosAuditoria.cantidad || "",
      timestamp,
      session.user.email,
      datosAuditoria.notas || "",
      urlFotos.join(", "),
      urlReporte,
      carpetas.success ? carpetas.rutaCompleta : ""
    ]);
    
    // 7⃣ Enviar correo con reporte
    const emailMgr = new EmailManagerRobusto(sm);
    const htmlReporte = generarHTMLAuditoria(datosCompletos);
    
    const resultadoEmail = emailMgr.enviarReporte(
      "DIARIO",
      {
        id: idAuditoria,
        fechaGeneracion: timestamp
      },
      ` Auditoría: ${cleanInfo.clean} - ${datosAuditoria.estado}`,
      htmlReporte
    );
    
    Logger.log("=== FIN guardarAuditoriaCompleta ===");
    Logger.log(` ID: ${idAuditoria}`);
    Logger.log(` Emails enviados: ${resultadoEmail.enviados || 0}`);
    
    return { 
      success: true, 
      message: "Auditoría guardada con reporte",
      idAuditoria: idAuditoria,
      urlReporte: urlReporte,
      carpeta: carpetas.success ? carpetas.rutaCompleta : null,
      emailEnviado: resultadoEmail.enviados > 0,
      fotos: fotosProcesadas.length
    };
    
  } catch (error) {
    Logger.log(" ERROR en guardarAuditoriaCompleta: " + error.toString());
    Logger.log("Stack: " + error.stack);
    return { success: false, message: error.toString() };
  }
}

