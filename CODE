//  VERSIÓN DEFINITIVA DE guardarConteoFisico
// Corregido: Email tipo CONTEO_FISICO + limpieza de códigos con cleanPartCode
function guardarConteoFisico(datos) {
  try {
    const sm = new SheetManager();
    const sheet = sm.getOrCreateSheet("ConteosFisicos");
    const session = getSessionUser(datos.sessionId);

    if (!session.success) {
      return { success: false, message: "Sesión inválida" };
    }

    const ubicacion = datos.ubicacion || "";
    const codigosEsperados = datos.codigosEsperados || [];
    const cantidadesContadas = datos.cantidadesContadas || {};
    const cantidadesNoEsperadas = datos.cantidadesNoEsperadas || {};

    //  APLICAR LIMPIEZA DE CÓDIGOS A TODOS LOS INPUTS
    const codigosEsperadosLimpios = codigosEsperados.map(c => cleanPartCode(c).clean);

    // Limpiar claves de los objetos de cantidades
    const cantidadesContadasLimpias = {};
    Object.entries(cantidadesContadas).forEach(([codigo, qty]) => {
      const codigoLimpio = cleanPartCode(codigo).clean;
      cantidadesContadasLimpias[codigoLimpio] = qty;
    });

    const cantidadesNoEsperadasLimpias = {};
    Object.entries(cantidadesNoEsperadas).forEach(([codigo, qty]) => {
      const codigoLimpio = cleanPartCode(codigo).clean;
      cantidadesNoEsperadasLimpias[codigoLimpio] = qty;
    });

    const contados = Object.keys(cantidadesContadasLimpias).length;
    const noEsperados = Object.keys(cantidadesNoEsperadasLimpias).length;
    const ausentesLista = codigosEsperadosLimpios.filter(c => !(c in cantidadesContadasLimpias));
    const ausentes = ausentesLista.length;
    const tasaCobertura = codigosEsperadosLimpios.length > 0
      ? ((contados / codigosEsperadosLimpios.length) * 100).toFixed(1)
      : 100;

    const timestamp = new Date().toLocaleString("es-PA");
    const idConteo = "CNT-" + Utilities.formatDate(new Date(), "GMT-5", "yyyyMMdd-HHmmss");

    const detalles = JSON.stringify({
      cantidadesContadas: cantidadesContadasLimpias,
      cantidadesNoEsperadas: cantidadesNoEsperadasLimpias,
      ausentes: ausentesLista
    });

    sheet.appendRow([
      timestamp,
      ubicacion,
      codigosEsperadosLimpios.length,
      contados,
      Math.max(0, ausentes),
      noEsperados,
      tasaCobertura + "%",
      session.user.email,
      detalles,
      idConteo
    ]);

    //  ENVIAR EMAIL CON TIPO CORRECTO: CONTEO_FISICO
    let emailEnviado = false;
    try {
      const emailMgr = new EmailManagerRobusto(sm);
      const asunto = ` Conteo Físico: ${ubicacion} (${tasaCobertura}% cobertura)`;
      const html = `
        <div style="font-family:Arial,sans-serif;max-width:600px;">
          <div style="background:#1d66c3;color:white;padding:25px;border-radius:8px 8px 0 0;text-align:center;">
            <h2 style="margin:0;"> Conteo Físico Completado</h2>
            <p style="margin:8px 0 0 0;opacity:0.9;">Ubicación: <strong>${ubicacion}</strong></p>
          </div>
          <div style="background:#f8f9fa;padding:20px;display:grid;grid-template-columns:repeat(2,1fr);gap:15px;">
            <div style="background:white;padding:15px;border-radius:8px;text-align:center;border-left:4px solid #1d66c3;">
              <div style="font-size:28px;font-weight:bold;color:#1d66c3;">${codigosEsperadosLimpios.length}</div>
              <div style="color:#666;font-size:13px;">Esperados</div>
            </div>
            <div style="background:white;padding:15px;border-radius:8px;text-align:center;border-left:4px solid #28a745;">
              <div style="font-size:28px;font-weight:bold;color:#28a745;">${contados}</div>
              <div style="color:#666;font-size:13px;">Contados</div>
            </div>
            <div style="background:white;padding:15px;border-radius:8px;text-align:center;border-left:4px solid #dc3545;">
              <div style="font-size:28px;font-weight:bold;color:#dc3545;">${Math.max(0, ausentes)}</div>
              <div style="color:#666;font-size:13px;">Ausentes</div>
            </div>
            <div style="background:white;padding:15px;border-radius:8px;text-align:center;border-left:4px solid #e65100;">
              <div style="font-size:28px;font-weight:bold;color:#e65100;">${noEsperados}</div>
              <div style="color:#666;font-size:13px;">No Esperados</div>
            </div>
          </div>
          <div style="background:#e3f2fd;padding:15px;text-align:center;">
            <strong style="font-size:20px;color:#1d66c3;">${tasaCobertura}% de cobertura</strong>
          </div>
          ${ausentes > 0 ? `<div style="background:#ffebee;padding:15px;border-radius:0 0 8px 8px;"><strong style="color:#dc3545;">❌ Ausentes (${ausentes}):</strong><br><small style="color:#666;">${ausentesLista.slice(0,30).join(', ')}${ausentesLista.length > 30 ? '...' : ''}</small></div>` : '<div style="background:#e8f5e9;padding:15px;text-align:center;"><strong style="color:#28a745;"> Todos los ítems encontrados</strong></div>'}
          <div style="padding:15px;text-align:center;color:#666;font-size:12px;">
            Realizado por: ${session.user.email} — ${timestamp} | ID: ${idConteo}
          </div>
        </div>`;

      //  TIPO CORRECTO: CONTEO_FISICO (no DIARIO)
      const resultado = emailMgr.enviarReporte("CONTEO_FISICO", { id: idConteo, fechaGeneracion: timestamp }, asunto, html);
      emailEnviado = resultado.enviados > 0;
      Logger.log(` Email conteo: enviados=${resultado.enviados}, fallidos=${resultado.fallidos}`);
    } catch (emailError) {
      Logger.log(" Error enviando email conteo: " + emailError);
    }

    return {
      success: true,
      idConteo: idConteo,
      emailEnviado: emailEnviado,
      metricas: {
        esperados: codigosEsperadosLimpios.length,
        contados: contados,
        ausentes: Math.max(0, ausentes),
        noEsperados: noEsperados,
        tasaCobertura: tasaCobertura
      }
    };

  } catch (error) {
    Logger.log("❌ Error en guardarConteoFisico: " + error.toString());
    return { success: false, message: error.toString() };
  }
}

// ========================================
//  CONTEO POR REFERENCIA
// ========================================

function guardarConteoReferencia(datos) {
  try {
    const sm = new SheetManager();
    const session = getSessionUser(datos.sessionId);

    if (!session.success) {
      return { success: false, message: "Sesión inválida" };
    }

    const referencias = datos.referencias || [];
    if (referencias.length === 0) {
      return { success: false, message: "No hay referencias para guardar" };
    }

    //  Obtener o crear hoja ConteoReferencia
    const sheet = sm.getOrCreateSheet("ConteoReferencia");

    // Asegurar encabezados
    if (sheet.getLastRow() === 0) {
      sheet.appendRow([
        "Timestamp", "ID Conteo", "Código", "Descripción", "Marca",
        "Ubicación", "Cantidad Física", "Total Físico Código", "Usuario"
      ]);
    }

    const timestamp = new Date().toLocaleString("es-PA");
    const idConteo = "CR-" + Utilities.formatDate(new Date(), "GMT-5", "yyyyMMdd-HHmmss");
    const usuario = session.user.email;

    // Guardar cada fila (código + ubicación)
    referencias.forEach(ref => {
      const codigoLimpio = cleanPartCode(ref.codigo).clean;
      const totalFisicoRef = ref.totalFisico || 0;

      if (ref.ubicaciones && ref.ubicaciones.length > 0) {
        ref.ubicaciones.forEach(u => {
          sheet.appendRow([
            timestamp,
            idConteo,
            codigoLimpio,
            ref.descripcion || "",
            ref.marca || "",
            u.ubicacion,
            u.cantidadFisica || 0,
            totalFisicoRef,
            usuario
          ]);
        });
      } else {
        // Sin ubicaciones — registrar igual
        sheet.appendRow([
          timestamp,
          idConteo,
          codigoLimpio,
          ref.descripcion || "",
          ref.marca || "",
          "SIN UBICACIÓN",
          0,
          totalFisicoRef,
          usuario
        ]);
      }
    });

    //  Actualizar fecha de "Último Inventario" en la hoja principal de "Inventario"
    try {
      const invSheet = sm.ss.getSheetByName("Inventario");
      if (invSheet) {
        let headers = invSheet.getRange(1, 1, 1, invSheet.getLastColumn() || 1).getValues()[0];
        let colUltimoInv = headers.indexOf("Último Inventario");
        
        if (colUltimoInv === -1) {
          colUltimoInv = headers.length;
          invSheet.getRange(1, colUltimoInv + 1).setValue("Último Inventario");
        }
        
        if (invSheet.getLastRow() > 1) {
          const codigosList = invSheet.getRange(2, 1, invSheet.getLastRow() - 1, 1).getValues();
          
          referencias.forEach(ref => {
            const codBuscar = cleanPartCode(ref.codigo).clean;
            for (let i = 0; i < codigosList.length; i++) {
              if (codigosList[i][0] && cleanPartCode(codigosList[i][0].toString()).clean === codBuscar) {
                invSheet.getRange(i + 2, colUltimoInv + 1).setValue(timestamp);
                break;
              }
            }
          });
          
          clearCacheInventario(); // Validar la obtención de datos nuevos en las próximas lecturas
        }
      }
    } catch (invErr) {
      Logger.log(" Error actualizando Último Inventario: " + invErr);
    }

    //  Construir HTML del email
    const totalGlobal = referencias.reduce((s, r) => s + (r.totalFisico || 0), 0);

    const filasEmail = referencias.map(ref => {
      const codigoLimpio = cleanPartCode(ref.codigo).clean;
      const ubicFilas = (ref.ubicaciones || []).map(u =>
        `<tr>
           <td style="padding:6px 10px;font-size:12px;color:#555;">${u.ubicacion}</td>
           <td style="padding:6px 10px;text-align:center;font-weight:700;">${u.cantidadFisica}</td>
         </tr>`
      ).join('');

      return `
        <tr style="background:#f8f9fa;">
          <td colspan="2" style="padding:10px 12px;">
            <div style="font-weight:800;font-size:14px;color:#1d66c3;">${codigoLimpio}</div>
            ${ref.descripcion ? `<div style="font-size:12px;color:#666;">${ref.descripcion}${ref.marca ? ' · ' + ref.marca : ''}</div>` : ''}
          </td>
          <td style="padding:10px 12px;text-align:center;font-size:18px;font-weight:900;color:#28a745;background:#e8f5e9;">${ref.totalFisico || 0}</td>
        </tr>
        ${ubicFilas ? `<tr><td colspan="3" style="padding:0 10px 10px 20px;">
          <table style="width:100%;border-collapse:collapse;font-size:12px;">
            <tr style="background:#e3f2fd;"><th style="padding:4px 8px;text-align:left;">Ubicación</th><th style="padding:4px 8px;text-align:center;">Cant.</th></tr>
            ${ubicFilas}
          </table></td></tr>` : ''}`;
    }).join('');

    const html = `
      <div style="font-family:Arial,sans-serif;max-width:650px;">
        <div style="background:linear-gradient(135deg,#1d66c3 0%,#155ab5 100%);color:white;padding:25px;border-radius:8px 8px 0 0;text-align:center;">
          <h2 style="margin:0;"> Conteo por Referencia</h2>
          <p style="margin:8px 0 0 0;opacity:0.9;">${referencias.length} referencia(s) · ${totalGlobal} unidades totales</p>
        </div>
        <div style="background:#f8f9fa;padding:20px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:20px;">
            <div style="background:white;padding:15px;border-radius:8px;text-align:center;border-left:4px solid #1d66c3;">
              <div style="font-size:28px;font-weight:bold;color:#1d66c3;">${referencias.length}</div>
              <div style="color:#666;font-size:13px;">Referencias</div>
            </div>
            <div style="background:white;padding:15px;border-radius:8px;text-align:center;border-left:4px solid #28a745;">
              <div style="font-size:28px;font-weight:bold;color:#28a745;">${totalGlobal}</div>
              <div style="color:#666;font-size:13px;">Unidades Totales</div>
            </div>
          </div>
          <table style="width:100%;border-collapse:collapse;background:white;border-radius:8px;overflow:hidden;">
            <thead>
              <tr style="background:#1d66c3;color:white;">
                <th colspan="2" style="padding:10px 12px;text-align:left;">Referencia</th>
                <th style="padding:10px 12px;text-align:center;">Total Físico</th>
              </tr>
            </thead>
            <tbody>${filasEmail}</tbody>
          </table>
        </div>
        <div style="padding:15px;text-align:center;color:#999;font-size:12px;background:#f8f9fa;border-radius:0 0 8px 8px;">
          Realizado por: ${usuario} — ${timestamp} | ID: ${idConteo}
        </div>
      </div>`;

    //  Enviar email con tipo CONTEO_REFERENCIA
    let emailEnviado = false;
    try {
      const emailMgr = new EmailManagerRobusto(sm);
      const asunto = ` Conteo Referencia: ${referencias.length} código(s) · ${totalGlobal} unidades`;
      const resultado = emailMgr.enviarReporte(
        "CONTEO_REFERENCIA",
        { id: idConteo, fechaGeneracion: timestamp },
        asunto,
        html
      );
      emailEnviado = resultado.enviados > 0;
      Logger.log(` Email conteo referencia: enviados=${resultado.enviados}, fallidos=${resultado.fallidos}`);
    } catch (emailError) {
      Logger.log(" Error enviando email conteo referencia: " + emailError);
    }

    return {
      success: true,
      idConteo: idConteo,
      emailEnviado: emailEnviado,
      metricas: {
        totalReferencias: referencias.length,
        totalUnidades: totalGlobal
      }
    };

  } catch (error) {
    Logger.log("❌ Error en guardarConteoReferencia: " + error.toString());
    return { success: false, message: error.toString() };
  }
}

