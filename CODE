/**
 *  Versión pública con validación
 */
function obtenerDescripcionConGemini(codigo, marca = "") {
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(30000);
  } catch (e) {
    return {
      success: false,
      error: "Sistema ocupado, intenta de nuevo"
    };
  }
  
  try {
    const resultado = consultarGeminiParaPieza(codigo, marca);
    
    if (resultado.success) {
      return {
        success: true,
        tipo_vehiculo: resultado.datos.tipo_vehiculo,
        descripcion: resultado.datos.descripcion,
        marca: resultado.datos.marca,
        categoria: resultado.datos.categoria,
        confianza: resultado.datos.confianza,
        fuente: resultado.datos.fuente,
        notas: resultado.datos.notas,
        es_moto_o_marino: resultado.datos.es_moto_o_marino,
        fuentes_web: resultado.fuentes || [],
        fromCache: resultado.fromCache || false
      };
    }
    
    return {
      success: false,
      error: resultado.error || "Error al consultar IA",
      razon_rechazo: resultado.razon_rechazo || null
    };
    
  } finally {
    lock.releaseLock();
  }
}

