/**
 *  Obtener API Key desde Properties Service
 */
function obtenerAPIKeyGemini() {
  try {
    const properties = PropertiesService.getScriptProperties();
    const apiKey = properties.getProperty('GEMINI_API_KEY');
    
    if (!apiKey || apiKey.trim() === '') {
      throw new Error("❌ GEMINI_API_KEY no configurada en Properties Service");
    }
    
    return apiKey.trim();
  } catch (error) {
    Logger.log("❌ ERROR al obtener API Key: " + error.toString());
    throw error;
  }
}

/**
 *  CACHE DE CONSULTAS GEMINI
 */
function obtenerDescripcionCacheada(codigo) {
  const cache = CacheService.getScriptCache();
  const cacheKey = `gemini_${codigo}`;
  const cached = cache.get(cacheKey);
  
  if (cached) {
    Logger.log(" Respuesta obtenida de cache para: " + codigo);
    return JSON.parse(cached);
  }
  
  return null;
}

function guardarDescripcionEnCache(codigo, datos) {
  const cache = CacheService.getScriptCache();
  const cacheKey = `gemini_${codigo}`;
  const expirationInSeconds = GEMINI_CONFIG.CACHE_DURATION_HOURS * 3600;
  
  try {
    cache.put(cacheKey, JSON.stringify(datos), expirationInSeconds);
    Logger.log(" Respuesta guardada en cache para: " + codigo);
  } catch (e) {
    Logger.log(" No se pudo guardar en cache: " + e.toString());
  }
}

