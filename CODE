function reintentarEmailsFallidos() {
  try {
    const sm = new SheetManager();
    const auditSheet = sm.ss.getSheetByName("AuditoriaEmails");
    
    if (!auditSheet) {
      return { success: false, message: "Hoja de auditoría no encontrada" };
    }
    
    const datos = auditSheet.getDataRange().getValues();
    const ahora = new Date();
    let reintentados = 0;
    let exitosos = 0;
    
    // Buscar emails fallidos que necesitan reintento
    for (let i = 1; i < datos.length; i++) {
      const estado = datos[i][4]; // Estado
      const intentos = datos[i][5]; // Intentos
      const proximoReintentoStr = datos[i][6]; // ProximoReintento
      
      if (estado === "FALLIDO" && intentos < 3 && proximoReintentoStr) {
        const proximoReintento = new Date(proximoReintentoStr);
        
        if (ahora >= proximoReintento) {
          const tipoReporte = datos[i][1];
          const emailDestino = datos[i][2];
          const asunto = datos[i][3];
          
          // Intentar reenviar
          try {
            // Aquí necesitarías recrear el contenido del email
            // Por simplicidad, enviamos un email de notificación
            GmailApp.sendEmail(
              emailDestino,
              "Reintento: " + asunto,
              "Este es un reintento de un email que falló previamente.\n\nPor favor contacte al administrador si continúa recibiendo este mensaje."
            );
            
            // Actualizar registro como exitoso
            auditSheet.getRange(i + 1, 5).setValue("EXITOSO");
            auditSheet.getRange(i + 1, 6).setValue(intentos + 1);
            auditSheet.getRange(i + 1, 7).setValue("");
            
            exitosos++;
            
          } catch (error) {
            // Incrementar intentos y programar siguiente reintento
            const nuevoIntento = intentos + 1;
            const siguienteReintento = new Date(ahora.getTime() + 3600000); // +1 hora
            
            auditSheet.getRange(i + 1, 6).setValue(nuevoIntento);
            
            if (nuevoIntento < 3) {
              auditSheet.getRange(i + 1, 7).setValue(siguienteReintento.toLocaleString("es-PA"));
            } else {
              auditSheet.getRange(i + 1, 7).setValue("MÁXIMO DE INTENTOS");
            }
          }
          
          reintentados++;
        }
      }
    }
    
    return { 
      success: true, 
      reintentados: reintentados,
      exitosos: exitosos,
      message: `Se reintentaron ${reintentados} emails, ${exitosos} exitosos`
    };
    
  } catch (error) {
    console.error("Error en reintentos:", error);
    return { success: false, message: error.toString() };
  }
}

