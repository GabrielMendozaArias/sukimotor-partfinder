function crearNuevaUbicacion(datosUbicacion) {
  try {
    Logger.log("=== INICIO crearNuevaUbicacion ===");
    Logger.log("Datos recibidos: " + JSON.stringify(datosUbicacion));
    
    const sm = new SheetManager();
    const ubicacionesSheet = sm.getOrCreateSheet("Ubicaciones");
    
    // Validar campos requeridos
    if (!datosUbicacion.zona || !datosUbicacion.pasillo || !datosUbicacion.anaquel || 
        !datosUbicacion.rack || !datosUbicacion.nivel) {
      return { 
        success: false, 
        message: "Todos los campos son obligatorios para crear una ubicación" 
      };
    }
    
    // Construir código de ubicación: ZONA-PASILLO-ANAQUEL-RACK-NIVEL
    const codigoUbicacion = `${datosUbicacion.zona}-${datosUbicacion.pasillo}-${datosUbicacion.anaquel}-${datosUbicacion.rack}-${datosUbicacion.nivel}`;
    
    // Verificar si ya existe
    const datos = ubicacionesSheet.getDataRange().getValues();
    const existe = datos.slice(1).some(row => {
      const ubicacionExistente = row[0]; // Columna "Ubicación"
      return ubicacionExistente === codigoUbicacion;
    });
    
    if (existe) {
      return { 
        success: false, 
        message: `La ubicación ${codigoUbicacion} ya existe en el sistema` 
      };
    }
    
    // Generar ID único
    const idUbicacion = "UB-" + Date.now();
    
    // Agregar nueva ubicación
    // Columnas: ["Ubicación", "ID", "Zona", "Pasillo", "Anaquel", "Rack", "Nivel", "Estado"]
    ubicacionesSheet.appendRow([
      codigoUbicacion,
      idUbicacion,
      datosUbicacion.zona,
      datosUbicacion.pasillo,
      datosUbicacion.anaquel,
      datosUbicacion.rack,
      datosUbicacion.nivel,
      datosUbicacion.estado || "Activa"
    ]);
    
    // Limpiar caché
    clearCacheInventario();
    
    Logger.log(" Ubicación creada: " + codigoUbicacion);
    
    return { 
      success: true, 
      message: "Ubicación creada exitosamente",
      ubicacion: codigoUbicacion,
      id: idUbicacion
    };
    
  } catch (error) {
    Logger.log(" ERROR en crearNuevaUbicacion: " + error.toString());
    return { 
      success: false, 
      message: "Error al crear ubicación: " + error.toString() 
    };
  }
}

