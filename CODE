class SessionManager {
  constructor() {
    try {
      this.cache = CacheService.getScriptCache();
      if (!this.cache) {
        throw new Error("No se pudo acceder a CacheService");
      }
    } catch (error) {
      Logger.log("❌ Error en SessionManager constructor: " + error.toString());
      throw error;
    }
  }
  
  /**
   * Generar ID único de sesión
   */
  generateSessionId() {
    return Utilities.getUuid();
  }
  
  /**
   * Crear nueva sesión
   * @param {Object} userData - Datos del usuario
   * @param {String} sessionId - ID de sesión (opcional)
   * @return {Object} - {success: true/false, sessionId: "..."}
   */
  setSession(userData, sessionId = null) {
    try {
      if (!userData) {
        throw new Error("userData es null o undefined");
      }
      
      // Generar sessionId si no existe
      if (!sessionId) {
        sessionId = this.generateSessionId();
      }
      
      // Configuración de tiempo
      const EXPIRY_SECONDS = 4 * 60 * 60; // 4 horas
      
      // Claves únicas por sesión
      const sessionKey = "session_" + sessionId;
      const activityKey = "activity_" + sessionId;
      
      // Guardar datos en cache
      this.cache.put(sessionKey, JSON.stringify(userData), EXPIRY_SECONDS);
      this.cache.put(activityKey, new Date().getTime().toString(), EXPIRY_SECONDS);
      
      // Registrar en log
      this.registrarSesionActiva(userData.email, sessionId);
      
      Logger.log(" Sesión creada: " + userData.email + " (ID: " + sessionId.substring(0, 8) + "...)");
      
      return {
        success: true,
        sessionId: sessionId
      };
      
    } catch (error) {
      Logger.log("❌ Error en setSession: " + error.toString());
      return { success: false };
    }
  }
  
  /**
   * Obtener sesión activa
   * @param {String} sessionId - ID de sesión
   * @return {Object|null} - Datos del usuario o null
   */
  getSession(sessionId) {
    try {
      if (!sessionId) {
        return null;
      }
      
      const sessionKey = "session_" + sessionId;
      const activityKey = "activity_" + sessionId;
      
      const userJson = this.cache.get(sessionKey);
      const lastActivity = this.cache.get(activityKey);
      
      if (!userJson || !lastActivity) {
        return null;
      }
      
      // Verificar inactividad (30 minutos)
      const inactivityTime = new Date().getTime() - parseInt(lastActivity);
      const MAX_INACTIVITY = 30 * 60 * 1000;
      
      if (inactivityTime > MAX_INACTIVITY) {
        Logger.log(" Sesión expirada por inactividad");
        this.clearSession(sessionId);
        return null;
      }
      
      // Actualizar actividad
      this.updateActivity(sessionId);
      
      return JSON.parse(userJson);
      
    } catch (error) {
      Logger.log("❌ Error en getSession: " + error.toString());
      this.clearSession(sessionId);
      return null;
    }
  }
  
  /**
   * Actualizar última actividad
   * @param {String} sessionId - ID de sesión
   */
  updateActivity(sessionId) {
    try {
      if (!sessionId) return;
      
      const EXPIRY_SECONDS = 4 * 60 * 60;
      const activityKey = "activity_" + sessionId;
      this.cache.put(activityKey, new Date().getTime().toString(), EXPIRY_SECONDS);
    } catch (error) {
      Logger.log("Error actualizando actividad: " + error);
    }
  }
  
  /**
   * Cerrar sesión
   * @param {String} sessionId - ID de sesión
   * @return {Boolean}
   */
  clearSession(sessionId) {
    try {
      if (!sessionId) return false;
      
      const sessionKey = "session_" + sessionId;
      const activityKey = "activity_" + sessionId;
      
      // Obtener usuario antes de limpiar
      const userJson = this.cache.get(sessionKey);
      if (userJson) {
        const user = JSON.parse(userJson);
        this.registrarCierreSesion(user.email, sessionId);
      }
      
      this.cache.remove(sessionKey);
      this.cache.remove(activityKey);
      
      Logger.log(" Sesión cerrada (ID: " + sessionId.substring(0, 8) + ")");
      return true;
      
    } catch (error) {
      Logger.log("❌ Error en clearSession: " + error.toString());
      return false;
    }
  }
  
  /**
   * Verificar si sesión está activa
   * @param {String} sessionId - ID de sesión
   * @return {Boolean}
   */
  isSessionActive(sessionId) {
    try {
      return this.getSession(sessionId) !== null;
    } catch (error) {
      return false;
    }
  }
  
  /**
   * Registrar login en log
   */
  registrarSesionActiva(email, sessionId) {
    try {
      const sm = new SheetManager();
      const logSheet = sm.getOrCreateSheet("Log_Sesiones");
      
      if (logSheet.getLastRow() === 0) {
        logSheet.appendRow(["Fecha/Hora", "Usuario", "Acción", "Session ID", "Device Key"]);
      }
      
      logSheet.appendRow([
        new Date().toLocaleString("es-PA"),
        email,
        "LOGIN",
        sessionId.substring(0, 12),
        Session.getTemporaryActiveUserKey() || "N/A"
      ]);
      
    } catch (error) {
      Logger.log("Error en registro de sesión: " + error);
    }
  }
  
  /**
   * Registrar logout en log
   */
  registrarCierreSesion(email, sessionId) {
    try {
      const sm = new SheetManager();
      const logSheet = sm.ss.getSheetByName("Log_Sesiones");
      
      if (logSheet) {
        logSheet.appendRow([
          new Date().toLocaleString("es-PA"),
          email,
          "LOGOUT",
          sessionId.substring(0, 12),
          Session.getTemporaryActiveUserKey() || "N/A"
        ]);
      }
    } catch (error) {
      Logger.log("Error en registro de cierre: " + error);
    }
  }
}
// ========================================
//  AUTENTICACIÓN
// ========================================

function hashPIN(pin, salt = "") {
  if (!salt) {
    salt = Utilities.getUuid().substring(0, 16);
  }
  const hash = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, pin + salt);
  return { hash: Utilities.base64Encode(hash), salt: salt };
}

function verifyPIN(inputPIN, storedHash, salt) {
  const { hash } = hashPIN(inputPIN, salt);
  return hash === storedHash;
}

function authenticateUser(email, pin) {
  const sm = new SheetManager();
  const usuariosSheet = sm.ss.getSheetByName("Usuarios");
  const datos = usuariosSheet.getDataRange().getValues();
  
  for (let i = 1; i < datos.length; i++) {
    if (datos[i][0] === email && datos[i][6]) {
      const storedHash = datos[i][2];
      const salt = datos[i][3];
      
      if (verifyPIN(pin, storedHash, salt)) {
        const userData = {
          email: email,
          rol: datos[i][4],
          permisos: JSON.parse(datos[i][5])
        };
        
        const sessionMgr = new SessionManager();
        const result = sessionMgr.setSession(userData);
        
        if (result.success) {
          usuariosSheet.getRange(i + 1, 9).setValue(new Date().toLocaleString("es-PA"));
          
          return {
            success: true,
            email: email,
            rol: userData.rol,
            permisos: userData.permisos,
            sessionId: result.sessionId
          };
        }
      }
    }
  }
  
  return { success: false, message: "Email o PIN incorrecto" };
}

function getSessionUser(sessionId) {
  if (!sessionId) {
    return { success: false, message: "Sin sesión", requireLogin: true };
  }
  
  const sessionMgr = new SessionManager();
  const user = sessionMgr.getSession(sessionId);
  
  if (!user) {
    return { success: false, message: "Sesión expirada", requireLogin: true };
  }
  
  return { success: true, user: user };
}

function logoutUser(sessionId) {
  if (!sessionId) {
    return { success: false, message: "Sin sesión para cerrar" };
  }
  
  const sessionMgr = new SessionManager();
  sessionMgr.clearSession(sessionId);
  return { success: true };
}

